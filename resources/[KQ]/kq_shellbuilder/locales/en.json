      "sections": {
        "construction": {
          "title": "Construction Mode",
          "description": "Shape your structure by placing floors, walls, and doorways. This forms the foundation of your shell. To delete a specific element, make sure to select the same type."
        },
        "style": {
          "title": "Style Mode",
          "description": "Apply paint, change textures, and add structural elements like stairs and beams to customize your space."
        },
        "decorate": {
          "title": "Decorate Mode",
          "description": "Place furniture, props, wall art, and grime to add personality and realism to your shell. Press RMB on a placed decor to activate the precise placement gizmo. Allowing you to move the decor around within its tile"
        },
        "save": {
          "title": "Save & Menu",
          "description": "Set the shell name, choose a timecycle, and finalize before previewing or saving your work."
        }
      },
      "camera": {
        "title": "Camera Controls",
        "swivel": {
          "title": "Swivel Camera",
          "description": "Hold <strong>right mouse button</strong> and drag to rotate."
        },
        "move": {
          "title": "Move Camera",
          "description": "Hold <strong>Shift + right mouse button</strong> and drag to pan."
        },
        "zoom": {
          "title": "Zoom",
          "description": "Use <strong>scroll wheel</strong> to zoom in and out."
        }
      },
      "tips": {
        "title": "Tips & Tricks",
        "doorways": "Use \"Doorways\" on outer walls to freeze doors in place.",
        "warm_lighting": "Warm interior lighting: Use <span class=\"text-primary-lighter\">yellow</span> or <span class=\"text-brown-600\">brown</span> lights.",
        "cold_lighting": "Colder, commercial lighting: Use <span class=\"text-primary\">blue lights</span>.",
        "quarter_walls": "Quarter-walls help prevent players from falling off stairs.",
        "max_props": "Max props: <strong>{{ maxPropCount }}</strong> (tracked in the memory bar)."
      },
      "issues": {
        "title": "Common issues",
        "delete_element": {
          "issue": "I can not delete an element",
          "solution": "Make sure to have an element of the same type selected. For example, to delete a wall, go on the construction tab and select a wall type"
        },
        "black_screen": {
          "issue": "I see a black screen",
          "solution": "Make sure that you have placed at least one floor tile. If not, go to the construction tab and select \"Floor\""
        },
        "delete_floor": {
          "issue": "I want to delete a floor without wall being placed around it",
          "solution": "To do that, simply go to the style tab and use the floor style \"None\""
        },
        "delete_decoration": {
          "issue": "I can not delete a decoration item",
          "solution": "Each tile has 4 decoration slots (4 sides), make sure to press delete on the same side as your decoration is placed on"
        },
        "wrong_spawn": {
          "issue": "I spawn in a wrong place",
          "solution": "Make sure to setup the <span class=\"underline\">spawnpoint</span>. This can be done within the construction tab"
        }
      },
